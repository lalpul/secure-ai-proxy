# .env.example — copy to .env and fill in real values
# Never commit .env to version control.

# ── LLM Backend ────────────────────────────────────────────────────────
LLM_BACKEND=openai                        # "openai" = any OpenAI-compatible API

# Groq (recommended — fast and free tier available)
GROQ_API_KEY=gsk_your_key_here
OPENAI_BASE_URL=https://api.groq.com/openai/v1
MODEL_NAME=llama-3.3-70b-versatile

# OR: OpenAI
# OPENAI_API_KEY=sk-your_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# MODEL_NAME=gpt-4o

# ── Token config ───────────────────────────────────────────────────────
TOKEN_PREFIX=TKN
TOKEN_BYTES=4                             # produces 8-char hex suffix e.g. TKN_NAME_A3F1

# ── Debug (never true in production) ──────────────────────────────────
# DEBUG=true                              # enables /docs Swagger UI
